---
import PageLayout from "@/layouts/PageLayout.astro";
import { getAllPosts } from "@/data/posts";
import { groupByYear } from "@/lib/groupByYear";

const posts = await getAllPosts();
const postsByYear = groupByYear(posts, (post) => post.date.getFullYear());
---

<PageLayout title="Blog">
  <p>I typically write about web development, video games, or my own life.</p>

  <p>
    <a class="button" href="/subscribe/">Subscribe</a>
  </p>

  {
    postsByYear.map(([year, postList]) => (
      <>
        <h2>{year}</h2>
        {postList.map((post) => (
          <a class="infobox" href={post.url}>
            <span class="heading">{post.title}</span>
            <span class="description">{post.description}</span>
          </a>
        ))}
      </>
    ))
  }
</PageLayout>
