{
  "name": "wavebeem.com",
  "private": true,
  "version": "1.0.0",
  "description": "wavebeem.com",
  "type": "module",
  "scripts": {
    "new-post": "node ./bin/new-post.mjs",
    "webp": "node ./bin/webp.mjs",
    "favicon": "node ./bin/favicon.mjs",
    "photo": "node ./bin/photo.mjs",
    "dev": "npx netlify@22.2.2 dev",
    "start": "cross-env TZ=UTC eleventy --serve --quiet --port=1312",
    "start:lan": "MY_ELEVENTY_HOST=0.0.0.0 npm start",
    "upgrade": "npm-check -u",
    "test": "npm run typecheck",
    "typecheck": "tsc",
    "lint": "stylelint \"src/**/*.css\" --formatter unix",
    "prebuild": "npm run test",
    "build": "eleventy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wavebeem/wavebeem.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wavebeem/wavebeem.com/issues"
  },
  "homepage": "https://wavebeem.com",
  "dependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.2",
    "colorjs.io": "^0.5.0",
    "markdown-it": "14.3.0",
    "preact": "10.29.7",
    "preact-render-to-string": "6.7.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2"
  },
  "devDependencies": {
    "cross-env": "10.1.0",
    "glob": "^11.0.0",
    "npm-check": "^6.0.1",
    "prettier": "^3.5.3",
    "stylelint": "^16.10.0",
    "stylelint-config-recommended": "^14.0.1"
  }
}
